{
  "name": "ekm-viisid-api",
  "version": "0.0.1",
  "description": "Eesti Kirjandusmuuseumi rahvaviiside API",
  "keywords": [
    "loopback-application",
    "loopback"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">=10.16"
  },
  "scripts": {
    "build": "lb-tsc",
    "build:watch": "lb-tsc --watch",
    "lint": "npm run prettier:check && npm run eslint",
    "lint:fix": "npm run eslint:fix && npm run prettier:fix",
    "prettier:cli": "lb-prettier \"**/*.ts\" \"**/*.js\"",
    "prettier:check": "npm run prettier:cli -- -l",
    "prettier:fix": "npm run prettier:cli -- --write",
    "eslint": "lb-eslint --report-unused-disable-directives .",
    "eslint:fix": "npm run eslint -- --fix",
    "pretest": "npm run clean && npm run build",
    "test": "lb-mocha --allow-console-logs \"dist/__tests__\"",
    "posttest": "npm run lint",
    "test:dev": "lb-mocha --allow-console-logs dist/__tests__/**/*.js && npm run posttest",
    "docker:build": "docker build -t jaansusi/ekm-viisid-api .",
    "docker:run": "docker run -p 3000:3000 -d jaansusi/ekm-viisid-api",
    "docker:release": "npm run docker:build && docker push jaansusi/ekm-viisid-api",
    "database:create": "npx db-migrate db:create kivi --env createDb --config ./migrations/database.json",
    "database:drop": "npx db-migrate db:drop kivi --env createDb --config ./migrations/database.json",
    "database:migrate": "npx db-migrate up --env dev --config ./migrations/database.json",
    "preopenapi-spec": "npm run build",
    "openapi-spec": "node ./dist/openapi-spec",
    "prestart": "npm run database:migrate && npm run build",
    "start": "node -r source-map-support/register .",
    "clean": "lb-clean dist *.tsbuildinfo .eslintcache"
  },
  "repository": {
    "type": "git"
  },
  "author": "Jaan Susi <jaan.susi@gmail.com>",
  "license": "",
  "files": [
    "README.md",
    "dist",
    "src",
    "!*/__tests__"
  ],
  "dependencies": {
    "@loopback/authentication": "^7.3.0",
    "@loopback/authentication-jwt": "^0.9.0",
    "@loopback/authorization": "^0.9.0",
    "@loopback/boot": "^3.4.0",
    "@loopback/core": "^2.16.0",
    "@loopback/repository": "^3.6.0",
    "@loopback/rest": "^9.3.0",
    "@loopback/rest-crud": "^0.10.0",
    "@loopback/rest-explorer": "^3.3.0",
    "@loopback/service-proxy": "^3.2.0",
    "casbin": "^5.6.2",
    "db-migrate": "^0.11.12",
    "db-migrate-pg": "^1.2.2",
    "loopback-connector-postgresql": "^5.2.0",
    "tslib": "^2.0.0"
  },
  "devDependencies": {
    "@loopback/build": "^6.4.0",
    "@loopback/cli": "^2.21.0",
    "@loopback/eslint-config": "^10.2.0",
    "@loopback/testlab": "^3.4.0",
    "@types/node": "^10.17.59",
    "cross-env": "^7.0.3",
    "eslint": "^7.25.0",
    "source-map-support": "^0.5.19",
    "typescript": "~4.2.4"
  }
}

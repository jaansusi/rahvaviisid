{
  "name": "ekm-viisid-api",
  "version": "1.0.0",
  "description": "Eesti Kirjandusmuuseumi rahvaviiside API",
  "keywords": [
    "loopback-application",
    "loopback"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "lb-tsc",
    "build:watch": "lb-tsc --watch",
    "dev": "tsc-watch --onSuccess \"node -r source-map-support/register .\"",
    "lint": "npm run prettier:check && npm run eslint",
    "lint:fix": "npm run eslint:fix && npm run prettier:fix",
    "prettier:cli": "lb-prettier \"**/*.ts\" \"**/*.js\"",
    "prettier:check": "npm run prettier:cli -- -l",
    "prettier:fix": "npm run prettier:cli -- --write",
    "eslint": "lb-eslint --report-unused-disable-directives .",
    "eslint:fix": "npm run eslint -- --fix",
    "pretest": "npm run clean && npm run build",
    "test": "lb-mocha --allow-console-logs \"dist/__tests__\"",
    "posttest": "npm run lint",
    "test:dev": "lb-mocha --allow-console-logs dist/__tests__/**/*.js && npm run posttest",
    "docker:build": "docker build -t jaansusi/ekm-viisid-api .",
    "docker:run": "docker run -p 3000:3000 -d jaansusi/ekm-viisid-api",
    "docker:release": "npm run docker:build && docker push jaansusi/ekm-viisid-api",
    "docker:release:certustec": "docker buildx build --builder oci-builder --platform linux/amd64 -t registry.cluster.certustec.ee/ekm-viisid-api --output type=image,oci-mediatypes=true,push=true --provenance=false --sbom=false .",
    "database:migrate": "npx db-migrate up --config ./migrations/database.json",
    "preopenapi-spec": "npm run build",
    "openapi-spec": "node ./dist/openapi-spec",
    "start": "node -r source-map-support/register .",
    "clean": "lb-clean dist *.tsbuildinfo .eslintcache",
    "test:api": "npx playwright test --config=playwright.config.ts",
    "test:api:report": "npx playwright show-report"
  },
  "repository": {
    "type": "git"
  },
  "author": "Jaan Susi <jaan.susi@gmail.com>",
  "license": "UNLICENSED",
  "files": [
    "README.md",
    "dist",
    "src",
    "!*/__tests__"
  ],
  "dependencies": {
    "@loopback/authentication": "^11.0.14",
    "@loopback/authentication-jwt": "^0.15.14",
    "@loopback/authorization": "^0.15.14",
    "@loopback/boot": "^7.0.14",
    "@loopback/core": "^6.1.11",
    "@loopback/repository": "^7.0.14",
    "@loopback/rest": "^14.0.14",
    "@loopback/rest-crud": "^0.18.14",
    "@loopback/rest-explorer": "^7.0.14",
    "@loopback/service-proxy": "^7.0.14",
    "casbin": "^5.50.0",
    "db-migrate": "^0.11.14",
    "db-migrate-pg": "^1.5.2",
    "deep-object-diff": "^1.1.9",
    "dotenv": "^17.4.2",
    "express-rate-limit": "^8.4.1",
    "loopback-connector-postgresql": "^5.5.2",
    "loopback4-migration": "^1.3.0",
    "python-shell": "^3.0.1",
    "tmp": "^0.2.5",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@loopback/build": "^11.0.12",
    "@loopback/cli": "^6.2.5",
    "@loopback/eslint-config": "^15.0.5",
    "@loopback/testlab": "^7.0.13",
    "@playwright/test": "^1.59.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.9",
    "@types/pg": "^8.20.0",
    "@types/tmp": "^0.2.6",
    "cross-env": "^7.0.3",
    "pg": "^8.20.0",
    "source-map-support": "^0.5.21",
    "tsc-watch": "^7.2.0",
    "typescript": "~5.9.3"
  }
}
